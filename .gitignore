# Wally-installed package contents (generated by `wally install`)
# Track the directory itself via .gitkeep so Rojo $path references resolve
# before any packages are installed.
**/Packages/*
!**/Packages/.gitkeep

# Rojo build artefacts
*.rbxlx
*.rbxl

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
